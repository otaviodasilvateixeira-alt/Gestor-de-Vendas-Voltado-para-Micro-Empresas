<script>
    document.addEventListener('DOMContentLoaded', () => {
        const toggleBtn = document.getElementById('toggle-add-form-btn');
        const formContainer = document.getElementById('add-product-form-container');
        const form = document.getElementById('add-product-form');
        const cancelBtn = document.getElementById('cancel-add-btn');
        const tbody = document.getElementById('inventory-table-body');
        const paginationText = document.getElementById('pagination-text');

        // Initial Data seeding if empty for demo purposes (optional, but good for first load to match original design feel before they delete)
        const initialData = [
            { id: 1, name: 'Cadeira de Escritório Ergonômica', sku: 'SKU-OFF-001', category: 'Móveis de Escritório', qty: 142, price: 850.00, icon: 'chair' },
            { id: 2, name: 'Monitor Dell 27" 4K', sku: 'SKU-ELE-042', category: 'Eletrônicos', qty: 8, price: 2450.00, icon: 'desktop_windows' },
            { id: 3, name: 'Teclado Mecânico Keychron K8', sku: 'SKU-ELE-089', category: 'Acessórios', qty: 0, price: 680.00, icon: 'keyboard' },
            { id: 4, name: 'Mesa com Regulagem de Altura', sku: 'SKU-OFF-012', category: 'Móveis de Escritório', qty: 34, price: 1950.00, icon: 'desk' }
        ];

        let products = JSON.parse(localStorage.getItem('proledger_inventory'));
        if (!products) {
            products = initialData;
            saveProducts();
        }

        function saveProducts() {
            localStorage.setItem('proledger_inventory', JSON.stringify(products));
        }

        function toggleForm() {
            formContainer.classList.toggle('hidden');
        }

        toggleBtn.addEventListener('click', toggleForm);
        cancelBtn.addEventListener('click', (e) => {
            e.preventDefault();
            form.reset();
            toggleForm();
        });

        function getStatusInfo(qty) {
            if (qty <= 0) return { text: 'Esgotado', class: 'bg-error-container text-on-error-container' };
            if (qty <= 10) return { text: 'Estoque Baixo', class: 'bg-[#FFF3E0] text-[#E65100]' }; // Using original hex for low stock alert
            return { text: 'Em Estoque', class: 'bg-surface-variant text-on-surface' };
        }

        function renderTable() {
            tbody.innerHTML = '';
            
            if (products.length === 0) {
                tbody.innerHTML = `<tr><td colspan="7" class="px-md py-lg text-center text-on-surface-variant font-body-md">Nenhum produto cadastrado</td></tr>`;
                if(paginationText) paginationText.textContent = `Exibindo 0 produtos`;
                return;
            }

            products.forEach(p => {
                const status = getStatusInfo(p.qty);
                const priceFormatted = Number(p.price).toLocaleString('pt-BR', {style: 'currency', currency: 'BRL'});
                const isOutOfStock = p.qty <= 0;
                
                const tr = document.createElement('tr');
                tr.className = `border-b border-outline-variant hover:bg-surface-container-low transition-colors group ${isOutOfStock ? 'bg-surface-bright' : ''}`;
                
                const iconName = p.icon || 'inventory_2';
                
                tr.innerHTML = `
                    <td class="px-md py-sm">
                        <div class="flex items-center gap-sm">
                            <div class="w-10 h-10 rounded bg-surface-container-highest border border-outline-variant flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-on-surface-variant" style="font-size: 20px;">${iconName}</span>
                            </div>
                            <span class="font-medium ${isOutOfStock ? 'text-on-surface-variant' : ''}">${p.name}</span>
                        </div>
                    </td>
                    <td class="px-md py-sm text-on-surface-variant">${p.sku}</td>
                    <td class="px-md py-sm text-on-surface-variant">${p.category}</td>
                    <td class="px-md py-sm text-right ${isOutOfStock ? 'text-on-surface-variant' : ''}">${p.qty}</td>
                    <td class="px-md py-sm text-center">
                        <span class="inline-flex items-center px-[12px] py-[4px] rounded-full ${status.class} font-label-caps text-label-caps">
                            ${status.text}
                        </span>
                    </td>
                    <td class="px-md py-sm text-right ${isOutOfStock ? 'text-on-surface-variant' : ''}">${priceFormatted}</td>
                    <td class="px-sm py-sm text-right">
                        <button onclick="deleteProduct(${p.id})" class="text-on-surface-variant hover:text-error opacity-0 group-hover:opacity-100 transition-opacity p-xs rounded-full hover:bg-error-container flex items-center justify-center ml-auto" title="Remover Produto">
                            <span class="material-symbols-outlined" style="font-size: 20px;">delete</span>
                        </button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
            if(paginationText) paginationText.textContent = `Exibindo 1 a ${products.length} de ${products.length} produtos`;
        }

        window.deleteProduct = function(id) {
            if(confirm('Tem certeza que deseja remover este produto?')) {
                products = products.filter(p => p.id !== id);
                saveProducts();
                renderTable();
            }
        };

        form.addEventListener('submit', (e) => {
            e.preventDefault();
            const newProduct = {
                id: Date.now(),
                name: document.getElementById('prod-name').value,
                sku: document.getElementById('prod-sku').value,
                category: document.getElementById('prod-category').value,
                qty: parseInt(document.getElementById('prod-qty').value, 10),
                cost: parseFloat(document.getElementById('prod-cost').value),
                price: parseFloat(document.getElementById('prod-price').value),
                icon: 'inventory_2' // Default icon for new products
            };
            products.unshift(newProduct); // Add to beginning
            saveProducts();
            form.reset();
            toggleForm();
            renderTable();
        });

        // Initial render
        renderTable();
    });
</script>
