<script>
    // Initialize mock inventory if empty
    if (!localStorage.getItem('inventory')) {
        localStorage.setItem('inventory', JSON.stringify([
            { id: '1', name: 'Notebook Pro', stock: 15, price: 4500 },
            { id: '2', name: 'Smartphone X', stock: 30, price: 2500 },
            { id: '3', name: 'Teclado Mecânico', stock: 50, price: 350 }
        ]));
    }
    
    // Initialize sales if empty
    if (!localStorage.getItem('sales')) {
        localStorage.setItem('sales', JSON.stringify([]));
    }

    const inventory = JSON.parse(localStorage.getItem('inventory'));
    let sales = JSON.parse(localStorage.getItem('sales'));

    // Populate product select
    const productSelect = document.getElementById('sale-product');
    inventory.forEach(item => {
        if (item.stock > 0) {
            const option = document.createElement('option');
            option.value = item.id;
            option.textContent = `${item.name} (Estoque: ${item.stock})`;
            productSelect.appendChild(option);
        }
    });

    // Handle form submission
    document.getElementById('new-sale-form').addEventListener('submit', function(e) {
        e.preventDefault();
        
        const clientId = document.getElementById('sale-client').value;
        const productId = document.getElementById('sale-product').value;
        const quantity = parseInt(document.getElementById('sale-quantity').value);
        const value = parseFloat(document.getElementById('sale-value').value);
        
        // Find product and update stock
        const productIndex = inventory.findIndex(p => p.id === productId);
        if (productIndex !== -1 && inventory[productIndex].stock >= quantity) {
            inventory[productIndex].stock -= quantity;
            localStorage.setItem('inventory', JSON.stringify(inventory));
            
            // Add sale
            const newSale = {
                id: Date.now().toString(),
                date: new Date().toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' }),
                client: clientId,
                productName: inventory[productIndex].name,
                quantity: quantity,
                value: value,
                nfeStatus: 'Pendente'
            };
            
            sales.unshift(newSale); // Add to beginning
            localStorage.setItem('sales', JSON.stringify(sales));
            
            // Reset and close
            this.reset();
            document.getElementById('sale-form-modal').classList.add('hidden');
            
            // Re-render
            renderSales();
        } else {
            alert('Estoque insuficiente para esta venda.');
        }
    });

    function emitNfe(saleId) {
        const saleIndex = sales.findIndex(s => s.id === saleId);
        if (saleIndex !== -1) {
            sales[saleIndex].nfeStatus = 'Emitida';
            localStorage.setItem('sales', JSON.stringify(sales));
            renderSales();
        }
    }

    function renderSales() {
        const tbody = document.getElementById('sales-table-body');
        const emptyState = document.getElementById('empty-state');
        tbody.innerHTML = '';
        
        let totalValue = 0;
        let pendingNfe = 0;
        let emittedNfe = 0;

        if (sales.length === 0) {
            emptyState.classList.remove('hidden');
        } else {
            emptyState.classList.add('hidden');
            
            sales.forEach(sale => {
                totalValue += sale.value;
                if (sale.nfeStatus === 'Pendente') pendingNfe++;
                if (sale.nfeStatus === 'Emitida') emittedNfe++;

                const tr = document.createElement('tr');
                tr.className = 'border-b border-outline-variant hover:bg-surface-container-lowest transition-colors';
                
                const nfeBadgeClass = sale.nfeStatus === 'Emitida' 
                    ? 'bg-[#e3f2fd] text-[#1565c0]' 
                    : 'bg-surface-container-high text-on-surface-variant';
                
                const actionButton = sale.nfeStatus === 'Pendente'
                    ? `<button onclick="emitNfe('${sale.id}')" class="px-sm py-xs border border-primary text-primary rounded bg-surface hover:bg-surface-container-low transition-colors text-label-caps font-label-caps">Gerar NF-e</button>`
                    : `<span class="text-secondary material-symbols-outlined">check</span>`;

                tr.innerHTML = `
                    <td class="px-md py-sm">${sale.date}</td>
                    <td class="px-md py-sm">${sale.client}<br><span class="text-body-sm text-secondary">Ref: #${sale.id.slice(-4)}</span></td>
                    <td class="px-md py-sm">${sale.productName}</td>
                    <td class="px-md py-sm">${sale.quantity}</td>
                    <td class="px-md py-sm">R$ ${sale.value.toFixed(2).replace('.', ',')}</td>
                    <td class="px-md py-sm">
                        <span class="px-sm py-xs ${nfeBadgeClass} rounded-full text-[10px] font-bold uppercase tracking-wider">${sale.nfeStatus}</span>
                    </td>
                    <td class="px-md py-sm text-right">
                        ${actionButton}
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        // Update summary cards
        document.getElementById('total-sales-value').textContent = `R$ ${totalValue.toFixed(2).replace('.', ',')}`;
        document.getElementById('pending-nfe-count').textContent = pendingNfe;
        document.getElementById('emitted-nfe-count').textContent = emittedNfe;
    }

    // Initial render
    renderSales();
</script>
