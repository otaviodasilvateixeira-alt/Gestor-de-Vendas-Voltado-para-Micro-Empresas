<script>
    document.addEventListener('DOMContentLoaded', () => {
        const sales = JSON.parse(localStorage.getItem('vendas')) || [];
        const products = JSON.parse(localStorage.getItem('produtos')) || [];

        // Helper to format currency
        const formatCurrency = (value) => {
            return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(value);
        };

        // 1 & 2. Calculate Profit
        let totalProfit = 0;
        const profitByProduct = {};

        sales.forEach(sale => {
            const product = products.find(p => p.id === sale.productId || p.nome === sale.produto); // Assuming id or name match
            if (product && product.precoCusto) {
                const saleValue = sale.valorTotal / sale.quantidade; // Or sale.precoVenda if available
                const costPrice = parseFloat(product.precoCusto);
                const quantity = parseInt(sale.quantidade, 10);
                
                const profit = (saleValue - costPrice) * quantity;
                totalProfit += profit;

                const productName = product.nome;
                if (!profitByProduct[productName]) {
                    profitByProduct[productName] = 0;
                }
                profitByProduct[productName] += profit;
            }
        });

        document.getElementById('kpi-profit').textContent = formatCurrency(totalProfit);

        // 3. Dynamic Profit by Product Summary
        const profitContainer = document.getElementById('profit-by-product-container');
        if (Object.keys(profitByProduct).length > 0) {
            let html = '<ul class="divide-y divide-outline-variant">';
            for (const [productName, profit] of Object.entries(profitByProduct)) {
                html += `
                    <li class="py-sm px-md flex justify-between items-center hover:bg-surface-container-low transition-colors">
                        <span class="text-body-md font-medium text-primary">${productName}</span>
                        <span class="text-data-tabular font-bold text-tertiary-container">${formatCurrency(profit)}</span>
                    </li>
                `;
            }
            html += '</ul>';
            profitContainer.innerHTML = html;
        } else {
            profitContainer.innerHTML = '<p class="text-body-md text-secondary text-center p-xl">Nenhum dado de lucro disponível. Registre vendas e custos de produtos.</p>';
        }

        // Example calculation for A Receber / A Pagar (assuming basic structure or static fallback if not in localStorage)
        // For a full implementation, you'd need 'contas_receber' and 'contas_pagar' in localStorage.
        // Here we just show how it would be populated dynamically if they existed, but we'll leave the static data as default or parse if available.
        
        const contasReceber = JSON.parse(localStorage.getItem('contas_receber')) || [];
        const contasPagar = JSON.parse(localStorage.getItem('contas_pagar')) || [];

        if(contasReceber.length > 0) {
             const totalReceivable = contasReceber.reduce((sum, item) => sum + parseFloat(item.valor), 0);
             document.getElementById('kpi-receivable').textContent = formatCurrency(totalReceivable);
             document.getElementById('kpi-receivable-count').textContent = `${contasReceber.length} faturas pendentes`;
             // Table generation could go here
        } else {
             // Keep static values if no dynamic data
             document.getElementById('kpi-receivable').textContent = 'R$ 5.200,00';
        }

        if(contasPagar.length > 0) {
             const totalPayable = contasPagar.reduce((sum, item) => sum + parseFloat(item.valor), 0);
             document.getElementById('kpi-payable').textContent = formatCurrency(totalPayable);
             document.getElementById('kpi-payable-count').textContent = `${contasPagar.length} boletos agendados`;
             // Table generation could go here
        } else {
            // Keep static values if no dynamic data
             document.getElementById('kpi-payable').textContent = 'R$ 2.100,00';
        }
    });
</script>
